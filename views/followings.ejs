<!doctype html>
<html lang="en">
<%- include('partials/html-head', {title: "Followings"}); -%>

<body>
  <div id="app" class="wrap">
    <%- include('partials/header', {title: "Followings"}); -%>

    <section>
      <%- include('partials/timeline-nav'); -%>
    </section>

    <section>
      <% if (follows.length === 0) { %>
      <div class="empty">You are not following anyone yet.</div>
      <% } else { %>
      <% follows.forEach((f) => { %>
      <article>
        <div>
          <strong>
            <a href="<%= f.url || f.actorUrl %>" target="_blank" rel="noopener">
              <%= f.name || f.handle %>
            </a>
          </strong>
          <small>@<%= f.handle %></small>
        </div>
        <% if (f.summary) { %>
        <div><%- f.summary %></div>
        <% } %>
        <small><a href="javascript:void(0)" class="red" v-on:click="unfollowRemote('<%= f._id %>')">unfollow</a></small>
      </article>
      <% }); %>
      <% } %>
    </section>

    <%- include('partials/pagination'); -%>
    <%- include('partials/footer'); -%>
  </div>
</body>

</html>