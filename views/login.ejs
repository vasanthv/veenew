<!doctype html>
<html lang="en">
<%- include('partials/html-head', {title: "Log in"}); -%>

<body>
  <div id="app" class="wrap">
    <%- include('partials/header', {title: "Log in"}); -%>

    <section class="mini-wrap">
      <form @submit.prevent="signIn">
        <div class="field">
          <label for="username">Username</label>
          <input type="text" id="username" placeholder="enter your username" v-model="authCreds.username" />
        </div>

        <div class="field">
          <label for="password">Password</label>
          <input type="password" id="password" placeholder="enter your password" v-model="authCreds.password" @keyup.enter="signIn" />
        </div>

        <button type="submit">log in</button>
        &nbsp;
        <a href="javascript:void(0)" class="bold" v-on:click="forgotPassword">forgot password?</a>

      </form>
      <div class="spacer"></div>
      <div class="small">Don't have an account yet? <a href="/signup" class="bold">Sign up</a></div>
    </section>
    <%- include('partials/footer'); -%>
  </div>
</body>

</html>