<!doctype html>
<html lang="en">
<%- include('partials/html-head', {title: "Timeliine"}); -%>

<body>
  <div id="app" class="wrap">
    <%- include('partials/header', {title: "Timeliine"}); -%>

    <section>
      <p class="small">Your fediverse handle: <code><%= myHandle %></code></p>
      <div class="field">
        <label for="follow-handle">Follow someone (user@instance)</label>
        <div class="flex">
          <input type="text" id="follow-handle" placeholder="e.g. alice@mastodon.social" v-model="followHandle" class="flex-1" />
          <button v-on:click="followRemote" :disabled="isLoading">follow</button>
        </div>
      </div>
    </section>

    <section>
      <% if (posts.length === 0) { %>
      <div class="empty">Nothing here yet. Follow someone to see their posts.</div>
      <% } else { %>
      <% posts.forEach((post) => { %>
      <article>
        <div class="flex">
          <div class="flex-1">
            <strong>
              <a href="<%= post.remoteUser.url || post.remoteUser.actorUrl %>" target="_blank" rel="noopener">
                <%= post.remoteUser.name || post.remoteUser.handle %>
              </a>
            </strong>
            <span class="small">@<%= post.remoteUser.handle %></span>
          </div>
        </div>
        <div class="content"><%- post.content %></div>
        <% if (Array.isArray(post.imageUrls) && post.imageUrls.length > 0) { %>
        <div class="content">
          <% post.imageUrls.forEach((src) => { %>
          <a href="<%= src %>" target="_blank" rel="noopener"><img src="<%= src %>" alt="" loading="lazy" /></a>
          <% }); %>
        </div>
        <% } %>
        <div class="small">
          <a href="<%= post.url %>" target="_blank" rel="noopener">
            <time datetime="<%= new Date(post.createdOn).toISOString() %>"><%= dayjs(post.createdOn).fromNow() %></time>
          </a>
        </div>
      </article>
      <% }); %>
      <% } %>
    </section>

    <%- include('partials/pagination'); -%>
    <%- include('partials/footer'); -%>
  </div>
</body>

</html>
