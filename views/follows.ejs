<!doctype html>
<html lang="en">
<%- include('partials/html-head', {title: "Follows"}); -%>

<body>
  <div id="app" class="wrap">
    <%- include('partials/header', {title: "Follows"}); -%>

    <section>
      <p class="small">Your fediverse handle: <code><%= myHandle %></code></p>
      <div class="field">
        <label for="follow-handle">Follow someone (user@instance)</label>
        <div class="flex">
          <input type="text" id="follow-handle" placeholder="e.g. alice@mastodon.social" v-model="followHandle" class="flex-1" />
          <button v-on:click="followRemote" :disabled="isLoading">follow</button>
        </div>
      </div>
    </section>

    <section>
      <% if (follows.length === 0) { %>
      <div class="empty">You are not following anyone yet.</div>
      <% } else { %>
      <table>
        <thead>
          <tr>
            <th>Handle</th>
            <th>Status</th>
            <th>Since</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% follows.forEach((f) => { %>
          <tr>
            <td>
              <a href="<%= f.url || f.actorUrl %>" target="_blank" rel="noopener"><%= f.name || f.handle %></a>
              <div class="small">@<%= f.handle %></div>
            </td>
            <td class="small"><%= f.accepted ? "accepted" : "pending" %></td>
            <td class="small"><%= dayjs(f.since).fromNow() %></td>
            <td>
              <button class="red" v-on:click="unfollowRemote('<%= f._id %>')">unfollow</button>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
      <% } %>
    </section>

    <%- include('partials/footer'); -%>
  </div>
</body>

</html>
