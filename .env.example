NODE_ENV=development
PORT=3000
MONGODB_URI=mongodb://localhost:27017/veenew-dev
SECRET=replace-with-a-long-random-secret

# Optional
DISABLE_CSRF=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
NO_REPLY_EMAIL=Veenew <noreply@email.veenew.com>
STRIPE_SECRET_KEY=

# --- Droplet / Docker deployment only (unused on App Platform) ---
# Shared secret between Caddy and /internal/tls-check. Generate with:
#   openssl rand -hex 32
TLS_CHECK_TOKEN=
# Base domain Caddy serves, e.g. veenew.com
APP_DOMAIN=
# Contact address for Let's Encrypt
ACME_EMAIL=
# Cloudflare API token with Zone:DNS:Edit on the zone (for the wildcard cert)
CLOUDFLARE_API_TOKEN=
# Better Stack log shipping. Copy both from the source's "Connect" page.
# Host has no scheme, e.g. s1234567.eu-nbg-2.betterstackdata.com
BETTERSTACK_INGEST_HOST=
BETTERSTACK_SOURCE_TOKEN=
